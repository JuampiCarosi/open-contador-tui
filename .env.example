# API SOS Contador
SOS_CONTADOR_BASE_URL=https://api.sos-contador.com/api-comunidad

# Autenticación: token directo (JWT) o email/password
SOS_CONTADOR_API_TOKEN=
SOS_CONTADOR_EMAIL=
SOS_CONTADOR_PASSWORD=

# ID de la CUIT a usar (opcional, si no se pone usa la primera disponible)
SOS_CONTADOR_CUIT_ID=

# Punto de venta a usar al crear facturas
SOS_CONTADOR_PUNTO_VENTA=1

# Resiliencia de red
SOS_CONTADOR_TIMEOUT_MS=9000
SOS_CONTADOR_RETRIES=2

# API cotización Dólar MEP (helper USD -> ARS)
DOLAR_MEP_BASE_URL=https://dolarapi.com/v1
DOLAR_MEP_TIMEOUT_MS=4000
DOLAR_MEP_RETRIES=1
DOLAR_MEP_CACHE_TTL_MS=300000
DOLAR_MEP_MAX_AGE_MINUTES=180

# Debug: guarda request/response en debug-email.log al enviar email (DEBUG_EMAIL=1)
# DEBUG_EMAIL=
